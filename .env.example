DINGTALK_APP_KEY=your_dingtalk_app_key
DINGTALK_APP_SECRET=your_dingtalk_app_secret
DINGTALK_PORT=8127

# 本地测试实时读取生产数据。个人令牌只放在被忽略的 .env，不能提交。
PRODUCTION_DATA_API_URL=https://product-flow-system.pages.dev
PRODUCTION_DATA_ACCESS_TOKEN=your_personal_production_data_token

# 平台凭证保险箱主密钥。生产值使用 Cloudflare Secret，必须是 32 字节随机值的 base64url。
PLATFORM_CREDENTIAL_MASTER_KEY=

# 仅用于事故回滚；默认必须关闭。开启后总览会显著标记兼容回滚口径。
VITE_DATA_CENTER_LEGACY_OVERVIEW_ROLLBACK=0

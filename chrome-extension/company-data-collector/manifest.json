{
  "manifest_version": 3,
  "name": "公司数据采集器",
  "version": "0.1.0",
  "description": "在公司 Chrome 中安全执行已登记平台的数据导出任务。",
  "key": "",
  "permissions": ["alarms", "downloads", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:17653/*",
    "https://erp.superboss.cc/*",
    "https://erpb.superboss.cc/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "公司数据采集器",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://erp.superboss.cc/*", "https://erpb.superboss.cc/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["providers/registry.js", "providers/kuaimai.js"],
      "matches": ["https://erp.superboss.cc/*", "https://erpb.superboss.cc/*"]
    }
  ]
}
